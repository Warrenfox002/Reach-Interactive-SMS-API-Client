{
    "name": "warrenfox002/reach-interactive-sms-api",
    "description": "Reach Interactive SMS API - PHP client library",
    "keywords": ["sms", "reach-interactive", "api", "php", "messaging"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Warren FOx",
            "email": "warrenfox002@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "ReachInteractive\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ReachInteractive\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "suggest": {
        "phpunit/phpunit": "For running tests"
    }
}
